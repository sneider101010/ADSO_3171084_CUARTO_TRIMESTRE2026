re del doctor es: {doctor1.nombre}\")\n","\n","    print(\"\\n**************** FIN DEL PROGRAMA PERSONAL MEDICO ****************\")\n","\n","\n","if __name__ == \"__main__\":\n","    main()\n"],"metadata":{"id":"sNnqJ4CRk8ad","executionInfo":{"status":"ok","timestamp":1773246737210,"user_tz":300,"elapsed":10,"user":{"displayName":"Camilo Hurtado","userId":"18334220698777090128"}},"outputId":"4c415ca2-f41d-4cb5-97a1-ba12f313f33b","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Carlos Ramirez: El doctor está atendiendo pacientes en consulta.\n","Laura Martinez: El enfermero está asistiendo a los pacientes.\n","Andres Gomez: El cirujano está realizando una cirugía.\n","Actualizando el nombre del doctor\n","El nuevo nombre del doctor es: Carlos Rojas\n","\n","**************** FIN DEL PROGRAMA PERSONAL MEDICO ****************\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"gfEKHmpeuOX4"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timestamp":1772626448714}]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}